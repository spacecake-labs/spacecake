    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "postinstall": "cp node_modules/ghostty-web/ghostty-vt.wasm public && node node_modules/@vscode/ripgrep/lib/postinstall.js",
