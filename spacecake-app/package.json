    "coverage": "vitest run --coverage",
    "e2e-test": "cross-env IS_PLAYWRIGHT=true playwright test",
    "e2e-show": "cross-env IS_PLAYWRIGHT=true SHOW_WINDOW=true playwright test",
    "changeset": "changeset",
    "prepare": "cd .. && husky spacecake-app/.husky"
