---

---

<section class="feature-showcase">
  <div class="showcase-container">
    <h2 class="showcase-heading">features</h2>

    <div class="showcase-layout">
      <!-- callout list: vertical on desktop, horizontal scroll tabs on mobile -->
      <div class="callout-list" role="tablist" aria-label="features">
        <button
          class="callout active"
          role="tab"
          aria-selected="true"
          aria-controls="panel-editor"
          id="tab-editor"
          data-feature="editor"
          tabindex="0"
        >
          <div class="callout-indicator"></div>
          <div class="callout-text">
            <span class="callout-label">beautiful markdown</span>
            <span class="callout-desc"
              >WYSIWYG editing with mermaid diagrams and checklists</span
            >
          </div>
        </button>

        <button
          class="callout"
          role="tab"
          aria-selected="false"
          aria-controls="panel-terminal"
          id="tab-terminal"
          data-feature="terminal"
          tabindex="-1"
        >
          <div class="callout-indicator"></div>
          <div class="callout-text">
            <span class="callout-label">integrated terminal</span>
            <span class="callout-desc"
              >run Claude Code with real-time context tracking</span
            >
          </div>
        </button>

        <button
          class="callout"
          role="tab"
          aria-selected="false"
          aria-controls="panel-git"
          id="tab-git"
          data-feature="git"
          tabindex="-1"
        >
          <div class="callout-indicator"></div>
          <div class="callout-text">
            <span class="callout-label">git integration</span>
            <span class="callout-desc"
              >commit, push, pull, manage branches, and track changes</span
            >
          </div>
        </button>

        <button
          class="callout"
          role="tab"
          aria-selected="false"
          aria-controls="panel-tasks"
          id="tab-tasks"
          data-feature="tasks"
          tabindex="-1"
        >
          <div class="callout-indicator"></div>
          <div class="callout-text">
            <span class="callout-label">agent tasks</span>
            <span class="callout-desc"
              >monitor pending, in-progress, and completed tasks</span
            >
          </div>
        </button>
      </div>

      <!-- preview container -->
      <div class="preview-outer">
        <div class="preview-container">
          <!-- mini chrome bar (sidebar icons) -->
          <div class="chrome-bar" aria-hidden="true">
            <button
              class="chrome-icon active"
              data-feature="editor"
              title="markdown editor"
              tabindex="-1"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
                ></path>
                <polyline points="14 2 14 8 20 8"></polyline>
              </svg>
            </button>
            <button
              class="chrome-icon"
              data-feature="terminal"
              title="terminal"
              tabindex="-1"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="4 17 10 11 4 5"></polyline>
                <line x1="12" y1="19" x2="20" y2="19"></line>
              </svg>
            </button>
            <button
              class="chrome-icon"
              data-feature="git"
              title="git"
              tabindex="-1"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="6" y1="3" x2="6" y2="15"></line>
                <circle cx="18" cy="6" r="3"></circle>
                <circle cx="6" cy="18" r="3"></circle>
                <path d="M18 9a9 9 0 0 1-9 9"></path>
              </svg>
            </button>
            <button
              class="chrome-icon"
              data-feature="tasks"
              title="tasks"
              tabindex="-1"
            >
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M9 11l3 3L22 4"></path>
                <path
                  d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
                ></path>
              </svg>
            </button>
          </div>

          <!-- panels -->
          <div class="panels-area">
            <!-- editor panel -->
            <div
              class="showcase-panel active"
              id="panel-editor"
              role="tabpanel"
              aria-labelledby="tab-editor"
            >
              <div class="panel-toolbar panel-toolbar-tabs">
                <div class="panel-tab active">
                  <svg
                    width="11"
                    height="11"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="panel-tab-icon-svg"
                  >
                    <path
                      d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
                    ></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                  </svg>
                  <span>ship-faster.md</span>
                  <span class="panel-tab-close">
                    <svg
                      width="10"
                      height="10"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <line x1="18" y1="6" x2="6" y2="18"></line>
                      <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                  </span>
                </div>
              </div>
              <div class="panel-body editor-body">
                <h3 class="editor-heading">ship faster</h3>
                <p class="editor-text">
                  write markdown plans.<br />explain code with diagrams.
                </p>

                <div class="mermaid-block">
                  <div class="mermaid-header">
                    <span>mermaid</span>
                  </div>
                  <div class="mermaid-body">
                    <div class="mermaid-flow">
                      <div class="flow-node">research</div>
                      <div class="flow-connector"></div>
                      <div class="flow-node">plan</div>
                      <div class="flow-connector"></div>
                      <div class="flow-node flow-node-active">implement</div>
                    </div>
                  </div>
                </div>

                <div class="checklist">
                  <div class="check-item checked">
                    <span class="check-box"></span>
                    <span>write specs, not code</span>
                  </div>
                  <div class="check-item checked">
                    <span class="check-box"></span>
                    <span>track progress visually</span>
                  </div>
                  <div class="check-item">
                    <span class="check-box"></span>
                    <span>ship faster</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- terminal panel -->
            <div
              class="showcase-panel"
              id="panel-terminal"
              role="tabpanel"
              aria-labelledby="tab-terminal"
              hidden
            >
              <!-- single toolbar: tabs left, badges right -->
              <div class="panel-toolbar panel-toolbar-terminal">
                <div class="sc-terminal-tabs">
                  <button
                    class="sc-terminal-tab active"
                    data-sc-term-tab="tab1"
                  >
                    <span class="sc-terminal-tab-label">✻ Claude Code</span>
                    <span class="sc-terminal-tab-close">
                      <svg
                        width="10"
                        height="10"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  </button>
                  <button class="sc-terminal-tab" data-sc-term-tab="tab2">
                    <span class="sc-terminal-tab-label">pnpm dev</span>
                    <span class="sc-terminal-tab-close">
                      <svg
                        width="10"
                        height="10"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </span>
                  </button>
                  <span class="sc-terminal-tab-add" title="new terminal (⌘T)">
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                  </span>
                </div>
                <div class="toolbar-badges-row">
                  <div class="panel-badge panel-badge-accent">
                    <div class="accent-dot"></div>
                    <span>Claude</span>
                  </div>
                  <div class="panel-badge panel-badge-outline">
                    <span>Opus 4.6 | 🧠 67% | 💰 $4.20</span>
                  </div>
                </div>
              </div>
              <!-- Claude Code tab content -->
              <div
                class="panel-body terminal-body sc-term-content active"
                data-sc-term-content="tab1"
              >
                <div class="terminal-ascii-overlay" id="terminal-ascii-overlay">
                  <pre class="ascii-pre" id="showcase-ascii-text"></pre>
                  <p class="ascii-message" id="showcase-ascii-message"></p>
                  <span class="ascii-cursor" id="showcase-ascii-cursor"></span>
                </div>
                <div class="terminal-welcome">
                  <div class="welcome-header">
                    ━━━━━ Claude Code ━━━━━━━━━━━━━━━━━━
                  </div>
                  <div class="welcome-body">
                    <div class="welcome-name">Welcome back Taylor!</div>
                    <div class="welcome-info">
                      <span class="welcome-emoji">🦀</span>
                      <span class="welcome-meta">Opus 4.5 · Claude Pro</span>
                    </div>
                    <div class="welcome-paths">
                      <span>taylor@spacecake.ai's Organization</span>
                      <span>~/Documents/GitHub/spacecake/</span>
                    </div>
                  </div>
                  <div class="welcome-footer">
                    <div class="welcome-tips-title">
                      Tips for getting started
                    </div>
                    <div class="welcome-tips-text">
                      Run ./init to create a CLAUDE.md file with instructions
                      for Claude
                    </div>
                    <div class="welcome-activity">
                      <span class="welcome-activity-label">Recent activity</span
                      >
                      <span class="welcome-activity-none"
                        >No recent activity</span
                      >
                    </div>
                  </div>
                </div>

                <div class="terminal-prompt">
                  <span class="prompt-arrow">❯</span>
                  <span class="prompt-block">■</span>
                  <span id="showcase-terminal-text"></span>
                  <span class="prompt-cursor" id="showcase-terminal-cursor"
                  ></span>
                </div>

                <div class="terminal-hint">? for shortcuts</div>
              </div>

              <!-- pnpm dev tab content -->
              <div
                class="panel-body terminal-body sc-term-content sc-vite-body"
                data-sc-term-content="tab2"
              >
                <div class="sc-vite-output">
                  <div class="sc-vite-cmd">$ pnpm dev</div>
                  <div class="sc-vite-ready">
                    <span class="sc-vite-brand">VITE</span>
                    <span class="sc-vite-dim"> v6.2.0</span>
                    <span class="sc-vite-green"> ready in</span>
                    <span class="sc-vite-white"> 284</span>
                    <span class="sc-vite-dim">ms</span>
                  </div>
                  <div class="sc-vite-urls">
                    <div>
                      <span class="sc-vite-green">➜</span>
                      <span class="sc-vite-white sc-vite-bold"
                        >&nbsp; Local: &nbsp;</span
                      >
                      <span class="sc-vite-cyan">http://localhost:5173/</span>
                    </div>
                    <div>
                      <span class="sc-vite-green">➜</span>
                      <span class="sc-vite-dim"
                        >&nbsp; Network: http://192.168.1.42:5173/</span
                      >
                    </div>
                    <div>
                      <span class="sc-vite-green">➜</span>
                      <span class="sc-vite-dim"
                        >&nbsp; press
                        <span class="sc-vite-white sc-vite-bold">h + enter</span
                        >
                        to show help</span
                      >
                    </div>
                  </div>
                  <div class="sc-vite-hmr">
                    <div>
                      <span class="sc-vite-dim">10:31:42</span>
                      <span class="sc-vite-cyan"> [vite]</span>
                      <span class="sc-vite-green">
                        hmr update /src/app.tsx</span
                      >
                    </div>
                    <div>
                      <span class="sc-vite-dim">10:31:44</span>
                      <span class="sc-vite-cyan"> [vite]</span>
                      <span class="sc-vite-green">
                        hmr update /src/components/editor.tsx</span
                      >
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- git panel -->
            <div
              class="showcase-panel"
              id="panel-git"
              role="tabpanel"
              aria-labelledby="tab-git"
              hidden
            >
              <!-- git toolbar: tabs + remote ops + branch -->
              <div class="panel-toolbar git-toolbar">
                <div class="git-toolbar-left">
                  <div class="git-tab-group">
                    <button class="git-tab active">changes <span class="git-tab-count">4</span></button>
                    <button class="git-tab">history</button>
                  </div>
                </div>
                <div class="git-toolbar-right">
                  <button class="git-remote-btn" title="fetch">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"></polyline><polyline points="23 20 23 14 17 14"></polyline><path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"></path></svg>
                  </button>
                  <button class="git-remote-btn" title="pull">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><polyline points="19 12 12 19 5 12"></polyline></svg>
                    <span class="git-remote-count git-remote-behind">2</span>
                  </button>
                  <button class="git-remote-btn" title="push">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline></svg>
                    <span class="git-remote-count git-remote-ahead">1</span>
                  </button>
                  <div class="panel-badge git-branch-badge">
                    <svg
                      width="12"
                      height="12"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="badge-icon icon-active"
                    >
                      <line x1="6" y1="3" x2="6" y2="15"></line>
                      <circle cx="18" cy="6" r="3"></circle>
                      <circle cx="6" cy="18" r="3"></circle>
                      <path d="M18 9a9 9 0 0 1-9 9"></path>
                    </svg>
                    <span>main</span>
                  </div>
                </div>
              </div>
              <div class="panel-body git-body">
                <div class="git-changes-view git-tab-view active" data-git-view="changes">
                  <!-- commit input area -->
                  <div class="git-commit-form">
                    <div class="git-commit-input-row">
                      <input
                        type="text"
                        class="git-commit-input"
                        placeholder="commit message..."
                        value="add project docs and config"
                        readonly
                      />
                    </div>
                    <div class="git-commit-actions">
                      <button class="git-commit-btn">commit</button>
                      <label class="git-amend-label">
                        <span class="git-checkbox git-checkbox-small"></span>
                        <span>amend</span>
                      </label>
                    </div>
                  </div>
                  <!-- file list -->
                  <div class="git-pane-scroll">
                    <div class="git-section">
                      <div class="git-section-hdr">
                        <span class="git-checkbox git-checkbox-checked"></span>
                        <span>changes</span>
                        <span class="git-count">4</span>
                        <span class="git-discard-all" title="discard all changes">
                          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"></path><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"></path></svg>
                        </span>
                      </div>
                      <div class="git-section-files">
                        <div class="git-file">
                          <span class="git-checkbox git-checkbox-checked"></span>
                          <svg
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            class="git-file-ico"
                            ><path
                              d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
                            ></path><polyline points="14 2 14 8 20 8"
                            ></polyline></svg
                          >
                          <span class="git-file-name">CLAUDE.md</span>
                          <span class="git-file-actions">
                            <span class="git-discard-btn" title="discard changes">
                              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"></path><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"></path></svg>
                            </span>
                          </span>
                          <span class="git-status git-status-m">M</span>
                        </div>
                        <div class="git-file">
                          <span class="git-checkbox git-checkbox-checked"></span>
                          <svg
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            class="git-file-ico"
                            ><path
                              d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
                            ></path><polyline points="14 2 14 8 20 8"
                            ></polyline></svg
                          >
                          <span class="git-file-name">notes.md</span>
                          <span class="git-file-actions">
                            <span class="git-discard-btn" title="discard changes">
                              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"></path><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"></path></svg>
                            </span>
                          </span>
                          <span class="git-status git-status-u">U</span>
                        </div>
                        <div class="git-file">
                          <span class="git-checkbox"></span>
                          <svg
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            class="git-file-ico"
                            ><path
                              d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
                            ></path><polyline points="14 2 14 8 20 8"
                            ></polyline></svg
                          >
                          <span class="git-file-name git-file-deleted">old-config.json</span>
                          <span class="git-file-actions">
                            <span class="git-discard-btn" title="discard changes">
                              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"></path><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"></path></svg>
                            </span>
                          </span>
                          <span class="git-status git-status-d">D</span>
                        </div>
                        <div class="git-file">
                          <span class="git-checkbox git-checkbox-checked"></span>
                          <svg
                            width="12"
                            height="12"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            class="git-file-ico"
                            ><path
                              d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"
                            ></path><polyline points="14 2 14 8 20 8"
                            ></polyline></svg
                          >
                          <span class="git-file-name">ship-faster.md</span>
                          <span class="git-file-actions">
                            <span class="git-discard-btn" title="discard changes">
                              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"></path><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"></path></svg>
                            </span>
                          </span>
                          <span class="git-status git-status-a">A</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="git-history-view git-tab-view" data-git-view="history">
                  <div class="git-history-list">
                    <div class="git-history-item git-history-item-selected">
                      <div class="git-history-row">
                        <span class="git-history-hash">eebd902</span>
                        <span class="git-history-date">Mar 22</span>
                      </div>
                      <div class="git-history-msg">fix: prevent data loss in updater</div>
                    </div>
                    <div class="git-history-item">
                      <div class="git-history-row">
                        <span class="git-history-hash">b38ead6</span>
                        <span class="git-history-date">Mar 21</span>
                      </div>
                      <div class="git-history-msg">fix: prevent popover from closing</div>
                    </div>
                    <div class="git-history-item">
                      <div class="git-history-row">
                        <span class="git-history-hash">baf3b82</span>
                        <span class="git-history-date">Mar 20</span>
                      </div>
                      <div class="git-history-msg">ci: redeploy website on release</div>
                    </div>
                    <div class="git-history-item">
                      <div class="git-history-row">
                        <span class="git-history-hash">b9ada07</span>
                        <span class="git-history-date">Mar 19</span>
                      </div>
                      <div class="git-history-msg">perf: optimise drag and drop</div>
                    </div>
                    <div class="git-history-item">
                      <div class="git-history-row">
                        <span class="git-history-hash">c858b13</span>
                        <span class="git-history-date">Mar 18</span>
                      </div>
                      <div class="git-history-msg">improvement: drag and drop UI</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- tasks panel -->
            <div
              class="showcase-panel"
              id="panel-tasks"
              role="tabpanel"
              aria-labelledby="tab-tasks"
              hidden
            >
